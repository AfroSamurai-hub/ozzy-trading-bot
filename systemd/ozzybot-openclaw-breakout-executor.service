[Unit]
Description=OzzyBot OpenClaw Breakout Executor (UNIFIED TESTNET)
After=network-online.target ozzybot-webhook.service ozzybot-openclaw-trend-executor.service
Wants=network-online.target ozzybot-webhook.service

[Service]
Type=oneshot
WorkingDirectory=/home/rick/ozzy-bot
EnvironmentFile=/home/rick/ozzy-bot/config/live-micro.env
Environment=HERMES_OPENCLAW_BREAKOUT_WEBHOOK_URL=http://127.0.0.1:5001/webhook
Environment=HERMES_OPENCLAW_BREAKOUT_EXECUTE=true
# v2026-06-15b — Post-loss hardening: closed 15m candles + tier quality.
Environment=HERMES_OPENCLAW_BREAKOUT_USE_CLOSED_CANDLE=true
Environment=HERMES_OPENCLAW_BREAKOUT_MIN_VOLUME_RATIO=1.00
Environment=HERMES_OPENCLAW_BREAKOUT_MIN_BODY_ATR=0.35
Environment=HERMES_OPENCLAW_BREAKOUT_MAX_REJECTION_WICK=0.45
Environment=HERMES_OPENCLAW_B_LANE_MIN_VOLUME_RATIO=1.25
Environment=HERMES_OPENCLAW_B_LANE_MIN_BODY_ATR=0.45
Environment=HERMES_OPENCLAW_B_LANE_MAX_REJECTION_WICK=0.35
Environment=HERMES_OPENCLAW_C_LANE_EXECUTE=false
Environment=HERMES_OPENCLAW_ANTI_CHASE_1H_RSI_BUY_MAX=74
Environment=HERMES_OPENCLAW_ANTI_CHASE_1H_RSI_SELL_MIN=26
Environment=HERMES_OPENCLAW_ANTI_CHASE_1H_EMA_DISTANCE_PCT=10
ExecStart=/home/rick/ozzy-bot/venv/bin/python /home/rick/ozzy-bot/core/openclaw_breakout_executor.py
StandardOutput=journal
StandardError=journal
Environment=PATH=/usr/bin:/usr/local/bin
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/home/rick/ozzy-bot
